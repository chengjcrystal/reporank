# Copy to .env and fill in.
# A GitHub Personal Access Token raises the API limit from 60 -> 5000 req/hr.
GITHUB_TOKEN=

# SQLite by default for zero-setup local runs.
# For "production" mode use Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/ghsearch
DATABASE_URL=sqlite:///./ghsearch.db

# Where the built inverted-index snapshot is written/loaded.
INDEX_PATH=./index_snapshot.pkl
